# ─────────────────────────────────────────────────────────────
# Interviewer — Credential & Configuration Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Google Sheets — the Spreadsheet that acts as the database
GOOGLE_SHEET_ID=your_google_spreadsheet_id_here

# Google Apps Script — the script project ID (from clasp)
GOOGLE_SCRIPT_ID=your_apps_script_project_id_here

# Comma-separated list of admin email addresses
# These users bypass the Interviewers whitelist check
ADMIN_EMAILS=admin@example.com,owner@example.com

# Optional: deployed web app URL (filled in after first deploy)
WEB_APP_URL=

# Optional: Google Cloud Project number (for OAuth / Execution API)
GCP_PROJECT_NUMBER=
